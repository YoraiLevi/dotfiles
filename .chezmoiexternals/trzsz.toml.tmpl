{{ if eq .chezmoi.os "windows" -}}
["./.local/bin/rz.exe"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "trzsz/lrzsz-win32" "lrzsz_*_windows_x86_64.zip" | quote }}
    path = "rz.exe"
    stripComponents = 1
    refreshPeriod = "168h"
    executable = true

["./.local/bin/sz.exe"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "trzsz/lrzsz-win32" "lrzsz_*_windows_x86_64.zip" | quote }}
    path = "sz.exe"
    stripComponents = 1
    refreshPeriod = "168h"
    executable = true

["./.local/bin/msys-2.0.dll"]
    type = "archive-file"
    url = {{ gitHubLatestReleaseAssetURL "trzsz/lrzsz-win32" "lrzsz_*_windows_x86_64.zip" | quote }}
    path = "msys-2.0.dll"
    stripComponents = 1
    refreshPeriod = "168h"
    executable = false
{{- end -}}
