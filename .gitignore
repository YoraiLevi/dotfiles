/*
!/.*

# Defensive: never track these even if explicitly added
.ssh/id_*
.ssh/*_rsa
.ssh/*_ed25519
.ssh/known_hosts
.netrc
.aws/credentials
.env
.env.*
*.pem
*.key

# uv virtualenv for git-hooks runner (regenerated by `uv sync`)
.dotfiles/githooks-runner/.venv/
.dotfiles/githooks-runner/**/__pycache__/
*.pyc
