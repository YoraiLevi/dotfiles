/*

# Defensive: never track these even if explicitly added
.ssh/id_*
.ssh/*_rsa
.ssh/*_ed25519
.ssh/known_hosts
.netrc
.aws/credentials
.env
.env.*
*.pem
*.key
.auth*
.auth/

# Only ~/.config/systemd/user — un-ignore each parent and re-ignore siblings so
# `git add -A` cannot pull in all of ~/.config (see gitignore "cannot re-include").

# !.config/
# .config/*
# !.config/systemd/
