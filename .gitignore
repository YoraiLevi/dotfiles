/*
!.dotfiles/
# Defensive: never track these even if explicitly added
.ssh/id_*
.ssh/*_rsa
.ssh/*_ed25519
.ssh/known_hosts
.netrc
.aws/credentials
.env
.env.*
*.pem
*.key
.auth*
.auth/

# Python
.venv/
**/__pycache__/
*.pyc


# Only ~/.config/systemd/user — un-ignore each parent and re-ignore siblings so
# when dotfiles add -A is executed these folders will be added to the index

!.agents/
!.powershell/
!.wsl2/
!.choco/
!.vscode/
