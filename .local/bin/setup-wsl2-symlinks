# This is not a "config warning" script.  It mirrors Windows paths into WSL by symlink
# (targets are relative to each link path, not absolute):
#   - %USERPROFILE%\.ssh → ~/.ssh, then chmod/chown on real targets behind symlinks (readlink -f);
#   - %USERPROFILE%\.wsl2\home → $HOME/…;
#   - %USERPROFILE%\.wsl2\etc → /etc/…;
#   - and chmod 644 on the real file if /etc/wsl.conf is a symlink (so a linked config keeps sane
#     permissions).
# Drive metadata for chmod to stick is validated in run_before_001_wsl2.sh, not here.

QUIET=0
FAST=0
CLEAN_BROKEN=0
DRY_RUN=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    -q | --quiet) QUIET=1 ;;
    -F | --fast) FAST=1 ;;
    -C | --clean-broken) CLEAN_BROKEN=1 ;;
    -n | --dry-run) DRY_RUN=1 ;;
    -h | --help)
      printf 'Usage: %s [-q|--quiet] [-F|--fast] [-C|--clean-broken] [-n|--dry-run]\n' "${0##*/}" >&2
      printf '  -q  No progress; silence cmd.exe stderr when resolving USERPROFILE.\n' >&2
      printf '  -F  Skip chmod/chown pass on ~/.ssh (faster on %%USERPROFILE%% / drvfs).\n' >&2
      printf '  -C  Remove dangling symlinks under $HOME and /etc whose target resolves under %%USERPROFILE%%.\n' >&2
      printf '  -n  Print actions only; no ln/rm/cp/chmod/chown/mkdir/mv.\n' >&2
      exit 0
      ;;
    *)
      printf 'Unknown option: %s\n' "$1" >&2
      printf 'Usage: %s [-q|--quiet] [-F|--fast] [-C|--clean-broken] [-n|--dry-run]\n' "${0##*/}" >&2
      exit 1
      ;;
  esac
  shift
done

say() {
  [ "$QUIET" -eq 1 ] || printf '%s\n' "$@"
}

dry_mkdir_p() {
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: mkdir -p -- $1"
  else
    mkdir -p -- "$1"
  fi
}

dry_mv_f() {
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: mv -f -- $1 $2"
  else
    mv -f -- "$1" "$2"
  fi
}

dry_chmod() {
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: chmod $*"
  else
    chmod "$@"
  fi
}

dry_chown() {
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: chown $*"
  else
    chown "$@"
  fi
}

dry_cp_f() {
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: cp -f -- $1 $2"
  else
    command cp -f -- "$1" "$2"
  fi
}

# Intended absolute path of a symlink's target (GNU realpath -m; works for broken links).
symlink_intended_abs() {
  local lnk="$1" raw dir
  [ -L "$lnk" ] || return 1
  raw=$(readlink -- "$lnk") || return 1
  dir=$(dirname -- "$lnk")
  if [ "${raw#/}" != "$raw" ]; then
    realpath -m -- "$raw" 2>/dev/null
  else
    realpath -m -- "$dir/$raw" 2>/dev/null
  fi
}

# True if intended path is $winpfx or a path under it (prefix-safe).
refers_under_win_profile() {
  local intended="$1" winpfx="$2"
  [ -n "$intended" ] && [ -n "$winpfx" ] || return 1
  case "$intended" in
    "$winpfx" | "$winpfx"/*) return 0 ;;
    *) return 1 ;;
  esac
}

# Resolve Windows %USERPROFILE% as a WSL path. Prefer existing ~/winHome (no cmd.exe).
# Run cmd.exe from /mnt/c or / so cwd is not a UNC path (avoids cmd's "UNC paths are not supported").
win_userprofile_wsl() {
  local win_raw prof_dir
  prof_dir=/mnt/c
  [ -d "$prof_dir" ] || prof_dir=/tmp
  [ -d "$prof_dir" ] || prof_dir=/
  if [ "$QUIET" -eq 1 ]; then
    win_raw="$(
      cd "$prof_dir" || exit 1
      cmd.exe /c "echo %USERPROFILE%" 2>/dev/null | tr -d '\r' | sed 's|\\|/|g'
    )"
  else
    win_raw="$(
      cd "$prof_dir" || exit 1
      cmd.exe /c "echo %USERPROFILE%" | tr -d '\r' | sed 's|\\|/|g'
    )"
  fi
  [ -n "$win_raw" ] || return 1
  if [ "$QUIET" -eq 1 ]; then
    wslpath -u "$win_raw" 2>/dev/null
  else
    wslpath -u "$win_raw"
  fi
}

WinWSL=""
if [ -e "$HOME/winHome" ]; then
  WinWSL="$(readlink -f -- "$HOME/winHome" 2>/dev/null || true)"
fi
if [ -z "$WinWSL" ] || [ ! -d "$WinWSL" ]; then
  WinWSL="$(win_userprofile_wsl)" || {
    echo "Could not resolve Windows USERPROFILE (cmd.exe / wslpath)." >&2
    exit 1
  }
fi

# Absolute WSL path to %%USERPROFILE%% (Windows tree); kept when dry-run skips ~/winHome symlinks.
PROFILE_ROOT="$WinWSL"

# Symlink $dst -> $src using a path relative to dirname($dst) (-s: do not resolve symlinks in $src).
ln_sf_rel() {
  local src="$1" dst="$2"
  local dst_dir relpath
  dst_dir=$(dirname -- "$dst")
  relpath=$(realpath -s --relative-to="$dst_dir" "$src") || return 1
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: ln -sf -- $relpath $dst"
    return 0
  fi
  ln -sf -- "$relpath" "$dst"
}

ln_sf_rel "$PROFILE_ROOT" "$HOME/winHome"
ln_sf_rel "$PROFILE_ROOT" "$HOME/homeWin"
if [ "$DRY_RUN" -eq 0 ]; then
  WinWSL="$HOME/winHome"
else
  WinWSL="$PROFILE_ROOT"
fi

# Absolute path of Windows profile (for clean-broken); uses ~/winHome when present, else PROFILE_ROOT.
WinProfileAbs="$(readlink -f -- "$HOME/winHome" 2>/dev/null)"
[ -n "$WinProfileAbs" ] || WinProfileAbs="$PROFILE_ROOT"

# Remove dangling symlinks whose intended target lies under WinProfileAbs (absolute or relative link text).
if [ "$CLEAN_BROKEN" -eq 1 ]; then
  if [ -z "$WinProfileAbs" ] || [ ! -d "$WinProfileAbs" ]; then
    echo "clean-broken: could not resolve WinProfileAbs from ~/winHome; skipping." >&2
  else
    winpfx="$(realpath -m -- "$WinProfileAbs" 2>/dev/null)"
    [ -n "$winpfx" ] || winpfx="$WinProfileAbs"
    while IFS= read -r -d '' path; do
      [ -L "$path" ] || continue
      case "$path" in
        "$HOME/winHome" | "$HOME/homeWin") continue ;;
      esac
      [ -e "$path" ] && continue
      intended="$(symlink_intended_abs "$path")" || continue
      refers_under_win_profile "$intended" "$winpfx" || continue
      if [ "$DRY_RUN" -eq 1 ]; then
        say "dry-run: clean-broken rm -- $path -> $intended"
      else
        say "clean-broken: rm $path -> $intended"
        rm -- "$path"
      fi
    done < <( {
      find "$HOME" -type l ! -path "$HOME/winHome" ! -path "$HOME/homeWin" -print0 2>/dev/null
      [ -d /etc ] && find /etc -type l -print0 2>/dev/null
    } )
  fi
fi

# Mirror USERPROFILE/.ssh into WSL ~/.ssh
WinDotSSH="$WinWSL/.ssh/"

if [ -d "$WinDotSSH" ]; then
  find "$WinDotSSH" \( -type f -o -type l \) -print0 | while IFS= read -r -d '' file; do
    rel="${file#"$WinDotSSH"}"
    target="$HOME/.ssh/$rel"
    say "$rel"
    dry_mkdir_p "$(dirname "$target")"
    if [ ! -L "$target" ]; then
      [ -e "$target" ] && dry_mv_f "$target" "$target.bak"
      ln_sf_rel "$file" "$target"
    fi
  done
else
  echo "Windows home directory not found" >&2
fi

# Set modes on the canonical file/dir behind each path (readlink -f) so deep symlinks
# to Windows files get the right perms. On /mnt/c, modes persist only with drvfs metadata
# in /etc/wsl.conf (e.g. [automount] options) after restart.
if [ "$FAST" -eq 0 ] && [ -d "$HOME/.ssh" ]; then
  find "$HOME/.ssh" -print0 | while IFS= read -r -d '' entry; do
    [ -e "$entry" ] || [ -L "$entry" ] || continue
    real=$(readlink -f -- "$entry" 2>/dev/null) || continue
    [ -n "$real" ] && [ -e "$real" ] || continue
    if [ -d "$real" ]; then
      dry_chmod 700 -- "$real"
    else
      base=$(basename -- "$entry")
      case "$base" in
        known_hosts)
          dry_chmod 644 -- "$real"
          ;;
        *.pub)
          dry_chmod 644 -- "$real"
          ;;
        config|authorized_keys)
          dry_chmod 600 -- "$real"
          ;;
        *)
          dry_chmod 600 -- "$real"
          ;;
      esac
      # Ensure the user running the script (root) owns the target
      dry_chown "$(id -u):$(id -g)" -- "$real"
    fi
  done
fi

# Mirror USERPROFILE/.wsl2/home into WSL $HOME
WinHome="$WinWSL/.wsl2/home/"

if [ -d "$WinHome" ]; then
  find "$WinHome" \( -type f -o -type l \) | while read -r file; do
    rel="${file#"$WinHome"}"
    target="$HOME/$rel"
    say "$rel"
    dry_mkdir_p "$(dirname "$target")"
    if [ ! -L "$target" ]; then
      [ -e "$target" ] && dry_mv_f "$target" "$target.bak"
      ln_sf_rel "$file" "$target"
    fi
  done
else
  echo "Windows home directory not found" >&2
fi


# Mirror USERPROFILE/.agents/claude into WSL $HOME
WinClaude="$WinWSL/.agents/claude/"

# Define exclusion list (relative paths under WinClaude)
exclude_list=(
  ".claude.json"
  # Add more paths as needed, relative to $WinClaude
)

if [ -d "$WinClaude" ]; then
  find "$WinClaude" \( -type f -o -type l \) | while read -r file; do
    rel="${file#"$WinClaude"}"
    # Remove leading slash, if any
    rel="${rel#/}"
    skip=false
    for excluded in "${exclude_list[@]}"; do
      if [ "$rel" = "$excluded" ]; then
        skip=true
        break
      fi
    done
    if $skip; then
      say "Skipping excluded: $rel"
      continue
    fi
    target="$HOME/.claude/$rel"
    say "$rel"
    dry_mkdir_p "$(dirname "$target")"
    if [ ! -L "$target" ]; then
      [ -e "$target" ] && dry_mv_f "$target" "$target.bak"
      ln_sf_rel "$file" "$target"
    fi
  done
else
  echo "Windows .agents/claude directory not found" >&2
fi
ln_sf_rel "$WinClaude/.claude.json" "$HOME/.claude.json"

# Mirror USERPROFILE/.wsl2/etc into WSL /etc (may require running chezmoi with sufficient privileges for /etc).
WinEtc="$WinWSL/.wsl2/etc/"

if [ -d "$WinEtc" ]; then
  find "$WinEtc" \( -type f -o -type l \) | while read -r file; do
    rel="${file#"$WinEtc"}"
    target="/etc/$rel"
    say "etc: $rel"
    dry_mkdir_p "$(dirname "$target")"
    if [ ! -L "$target" ]; then
      [ -e "$target" ] && dry_mv_f "$target" "$target.bak"
      ln_sf_rel "$file" "$target"
    fi
  done
else
  echo "Windows .wsl2/etc directory not found" >&2
fi

WslConf="$WinWSL/.wsl2/wsl.conf" 
if [ -f "$WslConf" ]; then
  say "$WslConf"
  dry_cp_f "$WslConf" /etc/wsl.conf
  dry_chmod 644 -- /etc/wsl.conf
  dry_chown root:root -- /etc/wsl.conf
else
  echo "Windows .wsl2/wsl.conf file not found" >&2
fi

# Ensure all files in ~/.local/bin are executable
if [ -d "$HOME/.local/bin" ]; then
  find "$HOME/.local/bin" -type f | while read -r f; do
    if [ ! -x "$f" ]; then
      dry_chmod +x -- "$f"
    fi
  done
fi