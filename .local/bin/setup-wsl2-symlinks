# This is not a "config warning" script.  It mirrors Windows paths into WSL by symlink
# (targets are relative to each link path, not absolute):
#   - %USERPROFILE%\.ssh → ~/.ssh, then chmod/chown on real targets behind symlinks (readlink -f);
#   - %USERPROFILE%\.auth → ~/.auth;
#   - %USERPROFILE%\.wsl2\home → $HOME/…;
#   - %USERPROFILE%\.wsl2\etc → /etc/…;
#   - $HOME/.winHome and $HOME/.homeWin → %%USERPROFILE%% (any other top-level symlink to the same
#     profile is accepted for resolution; broken or stale mirrored symlinks are refreshed by re-linking);
#   - and chmod 644 on the real file if /etc/wsl.conf is a symlink (so a linked config keeps sane
#     permissions).
# Drive metadata for chmod to stick is validated in run_before_001_wsl2.sh, not here.

QUIET=0
FAST=0
CLEAN_BROKEN=0
DRY_RUN=0
while [ "$#" -gt 0 ]; do
  case "$1" in
    -q | --quiet) QUIET=1 ;;
    -F | --fast) FAST=1 ;;
    -C | --clean-broken) CLEAN_BROKEN=1 ;;
    -n | --dry-run) DRY_RUN=1 ;;
    -h | --help)
      printf 'Usage: %s [-q|--quiet] [-F|--fast] [-C|--clean-broken] [-n|--dry-run]\n' "${0##*/}" >&2
      printf '  -q  No progress; silence cmd.exe stderr when resolving USERPROFILE.\n' >&2
      printf '  -F  Skip chmod/chown pass on ~/.ssh (faster on %%USERPROFILE%% / drvfs).\n' >&2
      printf '  -C  Remove dangling symlinks under $HOME and /etc whose target resolves under %%USERPROFILE%%.\n' >&2
      printf '  -n  Print actions only; no ln/rm/cp/chmod/chown/mkdir/mv.\n' >&2
      exit 0
      ;;
    *)
      printf 'Unknown option: %s\n' "$1" >&2
      printf 'Usage: %s [-q|--quiet] [-F|--fast] [-C|--clean-broken] [-n|--dry-run]\n' "${0##*/}" >&2
      exit 1
      ;;
  esac
  shift
done

# Symlinks under $HOME → Windows %USERPROFILE%% (single definition; used throughout).
WIN_HOME_LINK="$HOME/.winHome"
HOME_WIN_LINK="$HOME/.homeWin"

say() {
  [ "$QUIET" -eq 1 ] || printf '%s\n' "$@"
}

dry_mkdir_p() {
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: mkdir -p -- $1"
  else
    mkdir -p -- "$1"
  fi
}

dry_mv_f() {
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: mv -f -- $1 $2"
  else
    mv -f -- "$1" "$2"
  fi
}

dry_chmod() {
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: chmod $*"
  else
    chmod "$@"
  fi
}

dry_chown() {
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: chown $*"
  else
    chown "$@"
  fi
}

dry_cp_f() {
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: cp -f -- $1 $2"
  else
    command cp -f -- "$1" "$2"
  fi
}

# True if relative path $1 matches any pattern in remaining args (bash [[ == ]] glob rules: * ? [...]).
rel_matches_exclude() {
  local rel="$1" pat
  shift
  for pat in "$@"; do
    [[ "$rel" == $pat ]] && return 0
  done
  return 1
}

# Intended absolute path of a symlink's target (GNU realpath -m; works for broken links).
symlink_intended_abs() {
  local lnk="$1" raw dir
  [ -L "$lnk" ] || return 1
  raw=$(readlink -- "$lnk") || return 1
  dir=$(dirname -- "$lnk")
  if [ "${raw#/}" != "$raw" ]; then
    realpath -m -- "$raw" 2>/dev/null
  else
    realpath -m -- "$dir/$raw" 2>/dev/null
  fi
}

# True if intended path is $winpfx or a path under it (prefix-safe).
refers_under_win_profile() {
  local intended="$1" winpfx="$2"
  [ -n "$intended" ] && [ -n "$winpfx" ] || return 1
  case "$intended" in
    "$winpfx" | "$winpfx"/*) return 0 ;;
    *) return 1 ;;
  esac
}

# Resolve Windows %USERPROFILE% as a WSL path.
# Run cmd.exe from /mnt/c or / so cwd is not a UNC path (avoids cmd's "UNC paths are not supported").
win_userprofile_wsl() {
  local win_raw prof_dir
  prof_dir=/mnt/c
  [ -d "$prof_dir" ] || prof_dir=/tmp
  [ -d "$prof_dir" ] || prof_dir=/
  if [ "$QUIET" -eq 1 ]; then
    win_raw="$(
      cd "$prof_dir" || exit 1
      cmd.exe /c "echo %USERPROFILE%" 2>/dev/null | tr -d '\r' | sed 's|\\|/|g'
    )"
  else
    win_raw="$(
      cd "$prof_dir" || exit 1
      cmd.exe /c "echo %USERPROFILE%" | tr -d '\r' | sed 's|\\|/|g'
    )"
  fi
  [ -n "$win_raw" ] || return 1
  if [ "$QUIET" -eq 1 ]; then
    wslpath -u "$win_raw" 2>/dev/null
  else
    wslpath -u "$win_raw"
  fi
}

# $1 = candidate directory; $2 = realpath of %%USERPROFILE%% from cmd (empty if cmd failed).
# When cmd worked, only that exact profile counts. Otherwise accept /mnt trees with .wsl2 or .ssh.
resolved_profile_ok() {
  local cand="$1" norm_cmd="$2" n
  [ -d "$cand" ] || return 1
  if [ -n "$norm_cmd" ]; then
    n="$(realpath -m -- "$cand" 2>/dev/null)" || return 1
    [ "$n" = "$norm_cmd" ]
  else
    case "$cand" in /mnt/*) ;; *) return 1 ;; esac
    [ -d "$cand/.wsl2" ] || [ -d "$cand/.ssh" ]
  fi
}

# Print absolute profile dir: try ~/.winHome / ~/.homeWin, then any other top-level symlink in $HOME,
# then fall back to cmd.exe/wslpath (so we never depend on a specific old symlink name).
resolve_windows_profile_dir() {
  local from_cmd="" norm_cmd="" cand="" link
  from_cmd="$(win_userprofile_wsl 2>/dev/null || true)"
  norm_cmd=""
  if [ -n "$from_cmd" ] && [ -d "$from_cmd" ]; then
    norm_cmd="$(realpath -m -- "$from_cmd" 2>/dev/null || true)"
  fi

  for anchor in "$WIN_HOME_LINK" "$HOME_WIN_LINK"; do
    cand="$(readlink -f -- "$anchor" 2>/dev/null || true)"
    if [ -n "$cand" ] && resolved_profile_ok "$cand" "$norm_cmd"; then
      printf '%s\n' "$cand"
      return 0
    fi
  done

  while IFS= read -r -d '' link; do
    case "$link" in
      "$WIN_HOME_LINK" | "$HOME_WIN_LINK") continue ;;
    esac
    cand="$(readlink -f -- "$link" 2>/dev/null || true)"
    [ -n "$cand" ] || continue
    resolved_profile_ok "$cand" "$norm_cmd" || continue
    printf '%s\n' "$cand"
    return 0
  done < <(find "$HOME" -mindepth 1 -maxdepth 1 -type l -print0 2>/dev/null)

  if [ -n "$norm_cmd" ] && [ -n "$from_cmd" ] && [ -d "$from_cmd" ]; then
    printf '%s\n' "$(readlink -f -- "$from_cmd" 2>/dev/null || printf '%s' "$from_cmd")"
    return 0
  fi

  return 1
}

WinWSL="$(resolve_windows_profile_dir)" || {
  echo "Could not resolve Windows USERPROFILE (no working profile symlink under \$HOME and cmd.exe/wslpath failed)." >&2
  exit 1
}

# Absolute WSL path to %%USERPROFILE%% (Windows tree); kept when dry-run skips $WIN_HOME_LINK symlinks.
PROFILE_ROOT="$WinWSL"

# Symlink $dst -> $src using a path relative to dirname($dst) (-s: do not resolve symlinks in $src).
ln_sf_rel() {
  local src="$1" dst="$2"
  local dst_dir relpath
  dst_dir=$(dirname -- "$dst")
  relpath=$(realpath -s --relative-to="$dst_dir" "$src") || return 1
  if [ "$DRY_RUN" -eq 1 ]; then
    say "dry-run: ln -sf -- $relpath $dst"
    return 0
  fi
  ln -sf -- "$relpath" "$dst"
}

# Make $dst a symlink to $src using a path relative to dirname($dst); refresh if wrong or dangling.
mirror_symlink() {
  local src="$1" dst="$2"
  local dst_dir relpath cur
  dst_dir=$(dirname -- "$dst")
  relpath=$(realpath -s --relative-to="$dst_dir" "$src") || return 1
  if [ -L "$dst" ]; then
    cur=$(readlink -- "$dst") || return 1
    if [ "$cur" = "$relpath" ] && [ -e "$dst" ]; then
      return 0
    fi
  elif [ -e "$dst" ]; then
    dry_mv_f "$dst" "$dst.bak"
  fi
  ln_sf_rel "$src" "$dst"
}

ln_sf_rel "$PROFILE_ROOT" "$WIN_HOME_LINK"
ln_sf_rel "$PROFILE_ROOT" "$HOME_WIN_LINK"
if [ "$DRY_RUN" -eq 0 ]; then
  WinWSL="$WIN_HOME_LINK"
else
  WinWSL="$PROFILE_ROOT"
fi

# Absolute path of Windows profile (for clean-broken); uses $WIN_HOME_LINK when present, else PROFILE_ROOT.
WinProfileAbs="$(readlink -f -- "$WIN_HOME_LINK" 2>/dev/null)"
[ -n "$WinProfileAbs" ] || WinProfileAbs="$PROFILE_ROOT"

# Remove dangling symlinks whose intended target lies under WinProfileAbs (absolute or relative link text).
if [ "$CLEAN_BROKEN" -eq 1 ]; then
  if [ -z "$WinProfileAbs" ] || [ ! -d "$WinProfileAbs" ]; then
    echo "clean-broken: could not resolve WinProfileAbs from $WIN_HOME_LINK; skipping." >&2
  else
    winpfx="$(realpath -m -- "$WinProfileAbs" 2>/dev/null)"
    [ -n "$winpfx" ] || winpfx="$WinProfileAbs"
    while IFS= read -r -d '' path; do
      [ -L "$path" ] || continue
      case "$path" in
        "$WIN_HOME_LINK" | "$HOME_WIN_LINK") continue ;;
      esac
      [ -e "$path" ] && continue
      intended="$(symlink_intended_abs "$path")" || continue
      refers_under_win_profile "$intended" "$winpfx" || continue
      if [ "$DRY_RUN" -eq 1 ]; then
        say "dry-run: clean-broken rm -- $path -> $intended"
      else
        say "clean-broken: rm $path -> $intended"
        rm -- "$path"
      fi
    done < <( {
      find "$HOME" -type l ! -path "$WIN_HOME_LINK" ! -path "$HOME_WIN_LINK" -print0 2>/dev/null
      [ -d /etc ] && find /etc -type l -print0 2>/dev/null
    } )
  fi
fi

# Mirror USERPROFILE/.ssh into WSL ~/.ssh
WinDotSSH="$WinWSL/.ssh/"

# Define exclusion list (glob patterns; relative paths under WinDotSSH)
ssh_exclude_list=(
  ".gitkeep"
  "*.bak"
  # Add more patterns as needed, relative to $WinDotSSH
)

if [ -d "$WinDotSSH" ]; then
  find "$WinDotSSH" \( -type f -o -type l \) -print0 | while IFS= read -r -d '' file; do
    rel="${file#"$WinDotSSH"}"
    rel="${rel#/}"
    if rel_matches_exclude "$rel" "${ssh_exclude_list[@]}"; then
      say "Skipping excluded: $rel"
      continue
    fi
    target="$HOME/.ssh/$rel"
    say "$rel"
    dry_mkdir_p "$(dirname "$target")"
    mirror_symlink "$file" "$target"
  done
else
  echo "Windows home directory not found" >&2
fi

# Set modes on the canonical file/dir behind each path (readlink -f) so deep symlinks
# to Windows files get the right perms. On /mnt/c, modes persist only with drvfs metadata
# in /etc/wsl.conf (e.g. [automount] options) after restart.
if [ "$FAST" -eq 0 ] && [ -d "$HOME/.ssh" ]; then
  find "$HOME/.ssh" -print0 | while IFS= read -r -d '' entry; do
    [ -e "$entry" ] || [ -L "$entry" ] || continue
    real=$(readlink -f -- "$entry" 2>/dev/null) || continue
    [ -n "$real" ] && [ -e "$real" ] || continue
    if [ -d "$real" ]; then
      dry_chmod 700 -- "$real"
    else
      base=$(basename -- "$entry")
      case "$base" in
        known_hosts)
          dry_chmod 644 -- "$real"
          ;;
        *.pub)
          dry_chmod 644 -- "$real"
          ;;
        config|authorized_keys)
          dry_chmod 600 -- "$real"
          ;;
        *)
          dry_chmod 600 -- "$real"
          ;;
      esac
      # Ensure the user running the script (root) owns the target
      dry_chown "$(id -u):$(id -g)" -- "$real"
    fi
  done
fi

# Mirror USERPROFILE/.auth into WSL ~/.auth
WinAuth="$WinWSL/.auth/"

# Define exclusion list (glob patterns; relative paths under WinAuth)
auth_exclude_list=(
  ".gitkeep"
  "*.bak"
  # Add more patterns as needed, relative to $WinAuth
)

if [ -d "$WinAuth" ]; then
  find "$WinAuth" \( -type f -o -type l \) | while read -r file; do
    rel="${file#"$WinAuth"}"
    # Remove leading slash, if any
    rel="${rel#/}"
    if rel_matches_exclude "$rel" "${auth_exclude_list[@]}"; then
      say "Skipping excluded: $rel"
      continue
    fi
    target="$HOME/.auth/$rel"
    say "$rel"
    dry_mkdir_p "$(dirname "$target")"
    mirror_symlink "$file" "$target"
  done
else
  echo "Windows .auth directory not found" >&2
fi

# Mirror USERPROFILE/.wsl2/home into WSL $HOME
WinHome="$WinWSL/.wsl2/home/"

# Define exclusion list (glob patterns; relative paths under WinHome)
home_exclude_list=(
  ".gitkeep"
  "*.bak"
  # Add more patterns as needed, relative to $WinHome
)

if [ -d "$WinHome" ]; then
  find "$WinHome" \( -type f -o -type l \) | while read -r file; do
    rel="${file#"$WinHome"}"
    rel="${rel#/}"
    if rel_matches_exclude "$rel" "${home_exclude_list[@]}"; then
      say "Skipping excluded: $rel"
      continue
    fi
    target="$HOME/$rel"
    say "$rel"
    dry_mkdir_p "$(dirname "$target")"
    mirror_symlink "$file" "$target"
  done
else
  echo "Windows home directory not found" >&2
fi


# Mirror USERPROFILE/.agents/claude into WSL $HOME
WinClaude="$WinWSL/.agents/claude/"

# Define exclusion list (glob patterns; relative paths under WinClaude)
exclude_list=(
  ".claude.json"
  ".gitkeep"
  "*.bak"
  # Add more patterns as needed, relative to $WinClaude
)

if [ -d "$WinClaude" ]; then
  find "$WinClaude" \( -type f -o -type l \) | while read -r file; do
    rel="${file#"$WinClaude"}"
    # Remove leading slash, if any
    rel="${rel#/}"
    if rel_matches_exclude "$rel" "${exclude_list[@]}"; then
      say "Skipping excluded: $rel"
      continue
    fi
    target="$HOME/.claude/$rel"
    say "$rel"
    dry_mkdir_p "$(dirname "$target")"
    mirror_symlink "$file" "$target"
  done
else
  echo "Windows .agents/claude directory not found" >&2
fi
mirror_symlink "$WinClaude/.claude.json" "$HOME/.claude.json"

# Mirror USERPROFILE/.wsl2/etc into WSL /etc (may require running chezmoi with sufficient privileges for /etc).
WinEtc="$WinWSL/.wsl2/etc/"

# Define exclusion list (glob patterns; relative paths under WinEtc)
etc_exclude_list=(
  ".gitkeep"
  "*.bak"
  # Add more patterns as needed, relative to $WinEtc
)

if [ -d "$WinEtc" ]; then
  find "$WinEtc" \( -type f -o -type l \) | while read -r file; do
    rel="${file#"$WinEtc"}"
    rel="${rel#/}"
    if rel_matches_exclude "$rel" "${etc_exclude_list[@]}"; then
      say "Skipping excluded: $rel"
      continue
    fi
    target="/etc/$rel"
    say "etc: $rel"
    dry_mkdir_p "$(dirname "$target")"
    mirror_symlink "$file" "$target"
  done
else
  echo "Windows .wsl2/etc directory not found" >&2
fi

WslConf="$WinWSL/.wsl2/wsl.conf" 
if [ -f "$WslConf" ]; then
  say "$WslConf"
  dry_cp_f "$WslConf" /etc/wsl.conf
  dry_chmod 644 -- /etc/wsl.conf
  dry_chown root:root -- /etc/wsl.conf
else
  echo "Windows .wsl2/wsl.conf file not found" >&2
fi

# Ensure all files in ~/.local/bin are executable
if [ -d "$HOME/.local/bin" ]; then
  find "$HOME/.local/bin" -type f | while read -r f; do
    if [ ! -x "$f" ]; then
      dry_chmod +x -- "$f"
    fi
  done
fi