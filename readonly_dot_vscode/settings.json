			// "editorOverviewRuler.wordHighlightStrongForeground": "#c0a0c0cc",
			// "editorOverviewRuler.wordHighlightTextForeground": "#a0a0a0cc",
			// === Buttons (Welcome view, "Initialize Repository", "Open Folder", dialog confirms — anything that's a clickable action button) ===
			"button.background": "#564b45", // Was #555357 cool gray — now warm dark, matches list active-selection bg
			"button.foreground": "#fff1f3", // Warm white text (was already this)
			"button.hoverBackground": "#6a5d54", // Lighter warm on hover
			"button.secondaryBackground": "#3a322e", // Secondary actions — darker, less prominent
			"button.secondaryForeground": "#d6c9c0", // Was #c1c0c0 cool gray — now body cream
			"button.secondaryHoverBackground": "#4a403c", // Lighter warm on hover
			"button.border": "#564b4500", // Transparent — let bg define the button shape
			"button.separator": "#3a322e", // Visual separator inside split buttons

			// === Dropdowns (the "..." trigger buttons in panel headers, settings dropdowns, language picker bottom-right) ===
