			"statusBarItem.errorForeground": "#c4576f", // Muted pink text — clearly "error" without screaming
			"statusBarItem.errorHoverBackground": "#564b45", // Standard warm hover
			"statusBarItem.warningBackground": "#3a322e", // Same as bar bg
			"statusBarItem.warningForeground": "#c9a84e", // Muted yellow text — clearly "warning" without glare
			"statusBarItem.warningHoverBackground": "#564b45", // Standard warm hover

			// Mode-specific — bar bg shifts subtly to a tinted dark so you can tell at a glance what state you're in. Text stays muted colored.
			"statusBar.debuggingBackground": "#452e1e", // Dark orange-brown tint — noticeably warmer than normal bar
			"statusBar.debuggingForeground": "#c4845a", // Muted orange text
			"statusBar.debuggingBorder": "#c4845a60", // Orange top edge — the strongest "you're debugging" signal
			"statusBar.noFolderBackground": "#332e2e", // Slightly cooler/darker than normal — feels "empty", subtly off
			"statusBar.noFolderForeground": "#7a6e64", // Dim warm text
			"statusBar.noFolderBorder": "#564b4540", // Warm edge
			"statusBarItem.remoteBackground": "#1e3528", // Dark green tint — clearly "connected" without being a neon slab
			"statusBarItem.remoteForeground": "#8ab393", // Muted green text — matches your comment color
			"statusBarItem.remoteHoverBackground": "#2a4535", // Slightly lighter green-dark on hover

			// "debugView.valueChangedHighlight": "#ffd866",
