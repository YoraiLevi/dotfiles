	},
	"editor.tokenColorCustomizations": {
		"[Monokai Pro (Filter Ristretto)]": {
			"textMateRules": [
				{
					"scope": [ // Cozy Color for comments
						"comment",
						"comment.block",
						"comment.line",
						"comment.block.documentation",
						"punctuation.definition.comment",
						"string.quoted.docstring.multi",
						"comment.block.documentation source",
						"string.quoted.docstring.multi.python",
						"string.quoted.double.block.python punctuation.definition.string.end.python",
						"string.quoted.double.block.python punctuation.definition.string.begin.python",
						"string.quoted.double.block.python",
						"punctuation.definition.string.begin.python",
						"punctuation.definition.string.end.python"
					],
					"settings": {
						"foreground": "#8ab393"
					}
				},
				{
					// JSON property keys — fix for "the keys are pure white" issue.
					// Active: Monokai pink (Ristretto-native, Monokai-friendly, fits pink-green preference).
					// Swap by replacing the foreground value below with one of:
					//   "#f9cc6c" — warm yellow (Ristretto)
					//   "#adda78" — warm green (Ristretto)
					//   "#d6c9c0" — body color (mutes keys to match body — calmer but loses key/value distinction)
					"scope": [
						"support.type.property-name.json",          // The key text itself (the property name)
						"meta.structure.dictionary.key.json string.quoted.double.json" // The surrounding double quotes
					],
					"settings": {
						"foreground": "#d6c9c0"
					}
				},
			],
		},
	},
