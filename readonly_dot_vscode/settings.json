			"sideBarTitle.foreground": "#fff1f3", // Big sidebar title above section headers (project name) — slight emphasis
			"sideBarSectionHeader.foreground": "#fff1f3c3", // Section headers (EXPLORER, SOURCE CONTROL, etc.) @ 76% — brighter than body so they read as headers
			"sideBarSectionHeader.border": "#fff1f33e", // Warm subtle separator under section headers (was pure white at 49%)
			"sideBarStickyScroll.border": "#fff1f33e", // Warm separator under sticky scroll (was pure white at 49%) — sticky scroll text inherits sideBar.foreground above

			// === List item states (apply to Explorer, Search results, Source Control, Outline, References view, anywhere with a list) ===
