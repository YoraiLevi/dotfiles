			"menubar.selectionBackground": "#564b45", // Hovered top-menu item
			"menubar.selectionForeground": "#fff1f3", // Hovered top-menu text

			// === Toolbar (icon buttons in panel headers: "+", refresh, collapse-all, "..." trigger icons in Explorer/SCM/Search) ===
			"toolbar.hoverBackground": "#3a322e", // Subtle warm hover on the icon buttons
			"toolbar.activeBackground": "#564b45", // Active/pressed state — matches list active selection
			"toolbar.hoverOutline": "#564b4500", // No outline on hover — bg change is enough

			// === Agent / Chat panel (the AI conversation sidebar — your messages, agent responses, code blocks) ===
			"chat.requestBackground": "#332e2a", // Your message bubble bg — slightly warmer/darker than panel bg so your messages visually separate from the agent's
			"chat.requestBorder": "#564b4540", // Subtle warm border around your message bubble
			"chat.slashCommandBackground": "#564b45", // Slash command pills (/edit, /explain, etc.) — warm dark chip
			"chat.slashCommandForeground": "#fd6883", // Slash command text — pink so they pop as actionable
