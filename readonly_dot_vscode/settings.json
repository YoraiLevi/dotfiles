			"list.activeSelectionBackground": "#564b45", // Selected item when sidebar has focus — clearly warm dark
			"list.activeSelectionForeground": "#fff1f3", // Selected text when sidebar focused — max-emphasis warm white
			"list.inactiveSelectionBackground": "#d6c9c01a", // Selected item when sidebar lost focus — warm cream @ ~10% (replaces the cool white-tint at 13%)
			"list.inactiveSelectionForeground": "#d6c9c0", // Inactive selection text — body color (calm)
			"list.focusBackground": "#564b4580", // Keyboard-navigated item bg — like active selection but more transparent
			"list.focusForeground": "#fff1f3", // Keyboard-focused text
			"list.focusOutline": "#fd6883", // Pink ring around the keyboard-focused item — strong visual cue for keyboard nav
			"list.highlightForeground": "#fd6883", // Matching characters when you type to filter (Ctrl+P, search panel filter, etc.) — pink so they pop
			"list.focusHighlightForeground": "#fd6883", // Same matching characters in the currently-focused item
			"list.deemphasizedForeground": "#7a6e64", // Faded items (gitignored/deleted in git views) — warm dim
			"list.errorForeground": "#fd6883", // Items in error state — Monokai pink (matches your bracket #1)
			"list.warningForeground": "#f9cc6c", // Items in warning state — Ristretto warm yellow
			"tree.indentGuidesStroke": "#fd6883", // *** TEMPORARY JARRING — BRIGHT PINK *** = ACTIVE folder path indent guides. Open Explorer (Ctrl+Shift+E), expand a deep folder, look for the bright pink vertical lines. Then tell me to dial back. (Subtle warm value was: "#564b45")
			"tree.inactiveIndentGuidesStroke": "#78dce8", // *** TEMPORARY JARRING — BRIGHT CYAN *** = INACTIVE folder paths indent guides. The connectors of OTHER expanded folders that aren't on your selected path. Cyan vs pink makes the difference obvious. (Subtle warm value was: "#3a322e")

			"selection.background": "#acacac6e", // Text-selection bg in non-editor inputs: agent chat textbox, search fields, settings UI, etc. Higher opacity than the editor selection so it stays visible against the slightly different sidebar/input backgrounds.
			"quickInput.foreground": "#a8a6a9", // Quick Input main text (Ctrl+P, command palette) — kept your existing dim gray; see notes if you want to align to body
			"quickInput.background": "#2a292b",
			"editorGutter.addedBackground": "#a3be8c",
			"editorGutter.deletedBackground": "#bf616a",
			"editorGutter.modifiedBackground": "#ebcb8b",
			"gitDecoration.addedResourceForeground": "#a3be8c",
			"gitDecoration.deletedResourceForeground": "#bf616a",
			"gitDecoration.ignoredResourceForeground": "#494949",
			"gitDecoration.modifiedResourceForeground": "#ebcb8b",
			"gitDecoration.untrackedResourceForeground": "#88c0d0",
			"minimapGutter.addedBackground": "#a3be8c",
