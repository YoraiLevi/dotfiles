			"textLink.foreground": "#f9cc6c", // Links in markdown preview, extension READMEs, welcome pages — Ristretto standard yellow, matches warning/find-match accent family
			"textLink.activeForeground": "#ffd866", // Same links when clicked/hovered — slightly brighter Monokai yellow

			// === Inline Chat (Ctrl+K popup that appears inside the editor) ===
			"inlineChat.background": "#2a292b", // Widget bg — matches input/quickInput bg
			"inlineChat.foreground": "#d6c9c0", // Widget text — cream
			"inlineChat.border": "#564b45", // Widget border — warm visible
			"inlineChat.shadow": "#1a161480", // Drop shadow — warm dark, subtle
			"inlineChatInput.background": "#332e2a", // Input field inside the inline chat — slightly warmer than widget bg
			"inlineChatInput.border": "#564b45", // Input border
			"inlineChatInput.focusBorder": "#fd6883", // Input border when typing — pink focus ring (matches list.focusOutline)
			"inlineChatInput.placeholderForeground": "#7a6e64", // Placeholder "Ask Cursor..." text — dim warm
			"inlineChatDiff.inserted": "#8ab39320", // Green tint for added code in inline diff — your comment green at 12%
			"inlineChatDiff.removed": "#c4576f20", // Pink tint for removed code in inline diff — muted pink at 12%

			// === Status bar (bottom strip: branch name, errors/warnings counts, line/col, encoding, language picker, Cursor usage indicator) ===
			"statusBar.foreground": "#d6c9c0", // Was a dim warm gray — now body cream for readability
			"statusBar.background": "#3a322e", // Slightly darker warm than editor bg — gives the bar visual separation without being jarring
			"statusBar.border": "#564b4540", // Subtle warm top edge separating bar from editor
			"statusBarItem.hoverBackground": "#564b45", // Hovering a status bar item — warm dark
			"statusBarItem.hoverForeground": "#fff1f3", // Hover text — warm white for clear feedback
			"statusBarItem.activeBackground": "#6a5d54", // Pressed/clicked state
			"statusBarItem.prominentBackground": "#564b45", // Prominent items (sync indicator, "Problems" toggle, lock indicator) — warm dark
			"statusBarItem.prominentForeground": "#fff1f3", // Prominent text — warm white
			"statusBarItem.prominentHoverBackground": "#6a5d54", // Prominent item on hover
			"statusBarItem.focusBorder": "#fd688300", // Transparent — no ring on keyboard focus

			// Error/warning count indicators — colored TEXT on bar bg, not colored slabs
