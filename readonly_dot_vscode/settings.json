			// "editor.focusedStackFrameHighlightBackground": "#ffd86640", // Monokai yellow @ 25% — classic "debugger is here"
			// "editor.focusedStackFrameHighlightBackground": "#a9dc7640", // Monokai green @ 25% — leans into your green preference
