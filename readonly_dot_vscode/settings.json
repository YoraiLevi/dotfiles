			"terminal.foreground": "#d6c9c0", // Terminal text — match editor body so the terminal panel doesn't read as "white" against the warmer editor
			"descriptionForeground": "#a39a92", // Secondary UI text (slash command descriptions, paths under filenames in Ctrl+P, settings hints) — bumped from #a39a92 for readability
			
			
			"input.foreground": "#d6c9c0",            // Text you're typing — match body
			"input.background": "#2a292b",            // Box background — slightly different from main bg, matches your existing quickInput.background
