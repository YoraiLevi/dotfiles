			"dropdown.foreground": "#d6c9c0", // Body cream text
			"dropdown.border": "#3a322e", // Subtle warm border
			"dropdown.listBackground": "#2a292b", // Background of the opened dropdown list

			// === Context menus (right-click, "..." panel header → menu items) — THIS is where the gray-bg/white-text combo most likely comes from ===
