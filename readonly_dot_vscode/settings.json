{
	"update.showReleaseNotes": true,
	"update.enableWindowsBackgroundUpdates": false,
	"cursor.cpp.enablePartialAccepts": true,
	"cursor.diffs.useCharacterLevelDiffs": true,
	"cursor.terminal.usePreviewBox": true,
	"editor.accessibilitySupport": "off",
	"editor.gotoLocation.multipleDeclarations": "gotoAndPeek",
	"editor.gotoLocation.multipleDefinitions": "gotoAndPeek",
	"editor.gotoLocation.multipleImplementations": "gotoAndPeek",
	"editor.gotoLocation.multipleReferences": "gotoAndPeek",
	"editor.gotoLocation.multipleTypeDefinitions": "gotoAndPeek",
	"editor.formatOnSaveMode": "modificationsIfAvailable",
	"references.preferredLocation": "view",
	"[python]": {
		"diffEditor.ignoreTrimWhitespace": true,
		"editor.defaultFormatter": "ms-python.black-formatter",
		"editor.wordWrap": "on",
		// "editor.formatOnSave": true,
		// "editor.codeActionsOnSave": {
		// "source.organizeImports": "explicit"
		// },
		"editor.formatOnType": true,
	},
	"python.testing.pytestEnabled": true,
	"python.languageServer": "None",
	"python.testing.unittestEnabled": false,
	"jupyter.askForKernelRestart": false,
	"jupyter.widgetScriptSources": [
		"jsdelivr.com",
		"unpkg.com"
	],
	"notebook.lineNumbers": "on",
	"notebook.navigation.allowNavigateToSurroundingCells": false,
	"notebook.output.scrolling": true,
	"notebook.output.textLineLimit": 80,
	"notebook.output.wordWrap": true,
	"powershell.enableProfileLoading": false,
	"files.autoSave": "onFocusChange",
	"files.hotExit": "onExitAndWindowClose", // No save to close pop up
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/.hg/store/**": true,
		"**/node_modules/**": true,
		"**/.pytest_cache/**": true,
		"**/__pycache__/**": true,
		"**/.venv/**": true
	},
	"git.autofetch": true,
	"git.pruneOnFetch": true,
	"git.branchProtection": [
		"release",
		"main",
		"master",
		"prod",
		"qa",
		"dev",
	],
	"git.mergeEditor": true,
	"git.blame.editorDecoration.enabled": false,
	"git.blame.statusBarItem.enabled": false,
	"git.suggestSmartCommit": false,
	"gitlens.views.commitDetails.files.layout": "tree",
	"diffEditor.ignoreTrimWhitespace": true,
	"diffEditor.codeLens": true,
	"diffEditor.renderSideBySide": true,
	"remote.autoForwardPortsSource": "hybrid",
	"search.searchOnType": true, // ctrl+shift+f auto search on typing in search
	"search.showLineNumbers": true,
	"search.decorations.badges": false,
	"terminal.integrated.suggest.enabled": false, // The suggestions are annoying. keep them off
	"terminal.integrated.scrollback": 90000,
	"vscode-default-keybindings.removeOSKeybindings": true,
	"vscode-default-keybindings.windowsKeybindings": true,
	"window.restoreWindows": "all", // important
	"explorer.openEditors.visible": 15,
	"workbench.editor.showTabs": "single",
	"workbench.editor.limit.enabled": true,
	"workbench.editor.limit.value": 10,
	"workbench.editorLargeFileConfirmation": 30,
	"workbench.sideBar.location": "right",
	"indentRainbow.indicatorStyle": "light",
	"indentRainbow.lightIndicatorStyleLineWidth": 3,
	"indentRainbow.colors": [
		"rgba(255, 255, 255, 0)",
		"rgba(255, 255, 255, 0.1)",
		"rgba(255, 255, 255, 0.2)",
		"rgba(255, 255, 255, 0.3)",
		"rgba(255, 255, 255, 0.4)",
		"rgba(255, 255, 255, 0.5)",
		"rgba(255, 255, 255, 0.6)",
		"rgba(255, 255, 255, 0.7)",
		"rgba(255, 255, 255, 0.8)",
		"rgba(255, 255, 255, 0.9)"
	],
	// the same colors as above but more visible
	"workbench.iconTheme": "Monokai Pro (Filter Ristretto) Icons",
	"workbench.colorTheme": "Monokai Pro (Filter Ristretto)",
	"workbench.colorCustomizations": {
		"[Monokai Pro (Filter Ristretto)]": {

