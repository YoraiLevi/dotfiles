			"terminal.hoverHighlightBackground": "#8d3e8d49",
			"minimap.infoHighlight": "#78dce8a5",
			"minimap.warningHighlight": "#fc9867a5",
			"minimap.errorHighlight": "#ff6188a5",
			"minimap.findMatchHighlight": "#afaf0e38",
			"minimap.selectionHighlight": "#c1c0c026",
			"minimap.selectionOccurrenceHighlight": "#979797ad", // Highlight in minimap for same content as selection  
			"editorBracketHighlight.foreground1": "#ff6188",
			"editorBracketHighlight.foreground2": "#78dce8",
			"editorBracketHighlight.foreground3": "#fc9867",
