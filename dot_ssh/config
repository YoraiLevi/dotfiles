Host calc1-104003
  HostName <proxy-host>
  User yorai
  Port 4142
  IdentityFile ~/.ssh/<path-to-private-key>
  ServerAliveInterval 60
  StrictHostKeyChecking accept-new

Host calc2-104004
  HostName 192.168.200.11
  User yorai
  Port 22
  IdentityFile ~/.ssh/<path-to-private-key>
  ProxyJump calc1-104003
  ServerAliveInterval 60
  StrictHostKeyChecking accept-new