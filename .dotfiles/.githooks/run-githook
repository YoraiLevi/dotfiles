#!/usr/bin/env bash
#
# Shared Git hook implementation. Each Git hook is a small script that execs
# this file with GIT_HOOK_NAME set (after exec, $0 would otherwise be run-githook).
#
# Design
# ------
# 1. dispatch — single case on HOOK_NAME routes to exactly one hook_* function.
#    That makes it obvious where to add behavior and keeps Git's "$@" intact
#    per hook (message file paths, ref names, etc.).
# 2. hook_* — one function per hook; start with log_hook and add commands,
#    or call shared helpers. Return non-zero from client hooks that support
#    --no-verify to block the Git operation.
# 3. hook_default — safety net if a new hook wrapper is added but case lags.
#
set -u

HOOK_NAME="${GIT_HOOK_NAME:-$(basename "$0")}"

log_hook() {
  printf '[githook] %s\n' "$HOOK_NAME" >&2
}

hook_default() {
  log_hook
}

# --- applypatch / am ---------------------------------------------------------

hook_applypatch_msg() {
  # Args: $1 = path to proposed commit message file
  log_hook
}

hook_pre_applypatch() {
  log_hook
}

hook_post_applypatch() {
  log_hook
}

# --- commit ------------------------------------------------------------------

hook_pre_commit() {
  log_hook
}

hook_pre_merge_commit() {
  log_hook
}

hook_prepare_commit_msg() {
  # Args: $1 = message file, $2 = source (message|template|merge|squash|commit)
  log_hook
}

hook_commit_msg() {
  # Args: $1 = path to proposed commit message
  log_hook
}

hook_post_commit() {
  log_hook
}

# --- branch / merge / rebase -------------------------------------------------

hook_pre_rebase() {
  # Args: upstream [, branch]
  log_hook
}

hook_post_checkout() {
  # Args: $1 = previous HEAD, $2 = new HEAD, $3 = 1 (branch) or 0 (file)
  log_hook
}

hook_post_merge() {
  # Args: $1 = squash flag
  log_hook
}

hook_post_rewrite() {
  # Args: $1 = amend | rebase; rewritten pairs on stdin
  log_hook
}

# --- remote ------------------------------------------------------------------

hook_pre_push() {
  # Args: $1 = remote name, $2 = remote URL; ref updates on stdin
  log_hook
}

hook_pre_receive() {
  # Stdin: lines "<old> <new> <ref>"
  log_hook
}

hook_update() {
  # Args: $1 = ref name, $2 = old sha, $3 = new sha
  log_hook
}

hook_post_receive() {
  log_hook
}

hook_post_update() {
  # Args: updated ref names
  log_hook
}

hook_reference_transaction() {
  # Args: $1 = preparing|prepared|committed|aborted; updates on stdin
  log_hook
}

hook_push_to_checkout() {
  # Args: $1 = proposed new HEAD commit
  log_hook
}

# --- maintenance / misc ------------------------------------------------------

hook_pre_auto_gc() {
  log_hook
}

hook_sendemail_validate() {
  # Args: $1 = email body file, $2 = headers file
  log_hook
}

hook_post_index_change() {
  # Args: $1 = working dir updated (0|1), $2 = skip-worktree may have changed
  log_hook
}

# --- git-p4 ------------------------------------------------------------------

hook_p4_changelist() {
  # Args: $1 = changelist message file
  log_hook
}

hook_p4_prepare_changelist() {
  log_hook
}

hook_p4_post_changelist() {
  log_hook
}

hook_p4_pre_submit() {
  log_hook
}

# --- dispatch ----------------------------------------------------------------

dispatch() {
  case "$HOOK_NAME" in
    applypatch-msg) hook_applypatch_msg "$@" ;;
    pre-applypatch) hook_pre_applypatch "$@" ;;
    post-applypatch) hook_post_applypatch "$@" ;;
    pre-commit) hook_pre_commit "$@" ;;
    pre-merge-commit) hook_pre_merge_commit "$@" ;;
    prepare-commit-msg) hook_prepare_commit_msg "$@" ;;
    commit-msg) hook_commit_msg "$@" ;;
    post-commit) hook_post_commit "$@" ;;
    pre-rebase) hook_pre_rebase "$@" ;;
    post-checkout) hook_post_checkout "$@" ;;
    post-merge) hook_post_merge "$@" ;;
    pre-push) hook_pre_push "$@" ;;
    pre-receive) hook_pre_receive "$@" ;;
    update) hook_update "$@" ;;
    post-receive) hook_post_receive "$@" ;;
    post-update) hook_post_update "$@" ;;
    reference-transaction) hook_reference_transaction "$@" ;;
    push-to-checkout) hook_push_to_checkout "$@" ;;
    pre-auto-gc) hook_pre_auto_gc "$@" ;;
    post-rewrite) hook_post_rewrite "$@" ;;
    sendemail-validate) hook_sendemail_validate "$@" ;;
    post-index-change) hook_post_index_change "$@" ;;
    p4-changelist) hook_p4_changelist "$@" ;;
    p4-prepare-changelist) hook_p4_prepare_changelist "$@" ;;
    p4-post-changelist) hook_p4_post_changelist "$@" ;;
    p4-pre-submit) hook_p4_pre_submit "$@" ;;
    *) hook_default "$@" ;;
  esac
}

dispatch "$@"
